# IDE files
#
# Covers JetBrains IDEs: IntelliJ, Android Studio, etc.
.idea/
# Covers VS Code
.vscode/

# Build files
#
# Generated by the build system
build/
.gradle/
captures/

# Local configuration
#
# Contains SDK location and other machine-specific paths
local.properties

# Keystore files
#
# Should not be committed to public repositories
*.jks
*.keystore

# Other generated files
#
# Log files, emulators, etc.
*.log
.DS_Store
*.iml